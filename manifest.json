{
  "manifest_version": 3,
  "name": "MindX K-Guardian",
  "version": "1.0.0",
  "description": "OpsCoPilot - Hỗ trợ chẩn đoán và quản trị tri thức vận hành cho IT Helpdesk MindX",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "K-Guardian",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://hrm.mindx.edu.vn/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://hrm.mindx.edu.vn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/content-script/index.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}